rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /orders/{orderId} {
      // Dashboard reads all orders (password-protected page, not public)
      allow read: if true;
      // Customer order page: allow approve (status → approved) only when token matches
      allow update: if (
        // Dashboard: may update status + statusHistory only
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'statusHistory'])
      ) || (
        // Customer approval: token must match, and only status + statusHistory change
        request.resource.data.token == resource.data.token &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'statusHistory']) &&
        request.resource.data.status == 'approved'
      );
      allow create, delete: if false;
    }
  }
}
