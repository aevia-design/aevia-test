rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /orders/{orderId} {
      // Dashboard reads orders via Web SDK (unauthenticated, password-protected page)
      allow read: if true;
      // Dashboard may update status + statusHistory only — no create or delete from browser
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'statusHistory']);
      allow create, delete: if false;
    }
  }
}
